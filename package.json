{
  "name": "@classytic/mongokit",
  "version": "3.10.2",
  "description": "Production-grade MongoDB repositories - smart pagination, events, and plugins. Built on @classytic/repo-core.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./pagination": {
      "types": "./dist/pagination/PaginationEngine.d.mts",
      "default": "./dist/pagination/PaginationEngine.mjs"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.mts",
      "default": "./dist/plugins/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "default": "./dist/utils/index.mjs"
    },
    "./actions": {
      "types": "./dist/actions/index.d.mts",
      "default": "./dist/actions/index.mjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.mts",
      "default": "./dist/ai/index.mjs"
    },
    "./query/primitives/geo": {
      "types": "./dist/query/primitives/geo.d.mts",
      "default": "./dist/query/primitives/geo.mjs"
    },
    "./query/primitives/coercion": {
      "types": "./dist/query/primitives/coercion.d.mts",
      "default": "./dist/query/primitives/coercion.mjs"
    },
    "./query/primitives/indexes": {
      "types": "./dist/query/primitives/indexes.d.mts",
      "default": "./dist/query/primitives/indexes.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mongodb",
    "mongoose",
    "repository",
    "repository-pattern",
    "data-access",
    "pagination",
    "cursor-pagination",
    "infinite-scroll",
    "offset-pagination",
    "keyset-pagination",
    "caching",
    "redis",
    "cache",
    "multi-tenant",
    "multi-tenancy",
    "vector-search",
    "embeddings",
    "atlas-search",
    "observability",
    "event-driven",
    "plugin-based",
    "zero-dependencies",
    "express",
    "fastify",
    "nestjs",
    "nextjs",
    "typescript"
  ],
  "author": "Classytic <classytic.dev@gmail.com> (https://github.com/classytic)",
  "contributors": [
    "Sadman Chowdhury (https://github.com/siam923)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/classytic/mongokit.git"
  },
  "bugs": {
    "url": "https://github.com/classytic/mongokit/issues"
  },
  "homepage": "https://github.com/classytic/mongokit#readme",
  "peerDependencies": {
    "mongoose": ">=9.4.1",
    "@classytic/repo-core": ">=0.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --project unit --project integration",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:all": "vitest run --project unit --project integration --project e2e",
    "test:watch": "vitest --project unit --project integration",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write",
    "format": "biome format src/ --write",
    "check": "biome ci src/ --diagnostic-level=error",
    "prepublishOnly": "npm run check && npm run build && npm run typecheck && npm run typecheck:tests && npm test",
    "publish:dry": "npm publish --dry-run --access public",
    "publish:npm": "npm publish --access public",
    "release": "npm run check && npm run build && npm run typecheck && npm run typecheck:tests && npm test && npm publish --access public",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "release:major": "npm version major && npm run release"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.10",
    "@classytic/repo-core": ">=0.1.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "knip": "^6.3.0",
    "mongodb-memory-server": "^10.4.3",
    "mongoose": "^9.4.1",
    "publint": "^0.3.18",
    "tsdown": "^0.21.8",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
