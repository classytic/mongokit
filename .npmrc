# Publishing configuration
access=public
registry=https://registry.npmjs.org/

# Deterministic installs — peers are declared explicitly in devDependencies, so
# never let npm silently auto-resolve a peer during development. (Optional peers
# like mongodb-memory-server are already never auto-installed for CONSUMERS via
# peerDependenciesMeta.optional; this governs THIS repo's own installs.)
auto-install-peers=false

